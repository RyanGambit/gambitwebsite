{
  "rewrites": [],
  "redirects": [
    {
      "source": "/#solutions",
      "destination": "/#work",
      "permanent": true
    },
    {
      "source": "/#productions",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/#changemakers",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/case-study/askellyn-ai-for-shared-lived-experience",
      "destination": "/case-study/askellyn",
      "permanent": true
    },
    {
      "source": "/case-study/askashleigh-ai-for-caregiver-support",
      "destination": "/case-study/askashleigh",
      "permanent": true
    },
    {
      "source": "/introducing-askellyn-breast-cancer-support",
      "destination": "/case-study/askellyn",
      "permanent": false
    },
    {
      "source": "/introducing-askellyn-worlds-first-ai-companion-for-breast-cancer-support",
      "destination": "/case-study/askellyn",
      "permanent": true
    },
    {
      "source": "/partners",
      "destination": "/get-started",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://embed.gambitco.io https://script.google.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com; font-src https://api.fontshare.com https://fonts.gstatic.com; img-src 'self' https://gambitco.io data:; frame-src https://chat.gambitco.io https://dm78pdaamzrpr.cloudfront.net https://formspree.io; connect-src 'self' https://script.google.com https://formspree.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io"
        }
      ]
    },
    {
      "source": "/og-(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}